{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "redirectApiRoute": {
        "ClusterId": "redirectApiCluster",
        "Match": {
          "Path": "redirect-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "api/{**catch-all}"
          }
        ]
      },
      "writeApiRoute": {
        "ClusterId": "writeApiCluster",
        "Match": {
          "Path": "write-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "api/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "productApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://localhost:5148/"
          }
        }
      },
      "aggregateApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://localhost:5293/"
          }
        }
      }
    }
  }
}
